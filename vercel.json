{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "echo \"no dependencies\"",
  "outputDirectory": "web",
  "framework": null,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" },
        { "key": "Content-Language", "value": "zh-CN" }
      ]
    }
  ]
}
